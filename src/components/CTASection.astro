---
import Button from "./Button.astro";

interface Props {
  title?: string;
  buttonText?: string;
  href?: string;
}

const {
  title = "Bereit für deinen neuen Auftritt?",
  buttonText = "Projekt Anfrage",
  href = "/Kontakt",
} = Astro.props;
---

<section class="cta">
  <div class="container cta__inner">
    <h2 class="cta__title">{title}</h2>
    <Button text={buttonText} href={href} variant="black" />
  </div>
</section>

<style>
  .cta {
    padding-block: var(--space-5xl);
    background: var(--color-background-pink);
    overflow: hidden;
  }

  .cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    text-align: center;
  }

  .cta__title {
    max-width: 40rem;
    font-size: var(--text-h1-size);
    line-height: var(--text-h1-lh);
    color: var(--color-black);

    transform: translateY(4rem);
    transition:
      opacity 1.8s cubic-bezier(0.22, 1, 0.36, 1) 0.1s,
      transform 1.8s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
  }

  .cta__title.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .cta__title {
      font-size: var(--text-h2-size);
      line-height: var(--text-h2-lh);
      max-width: 25rem;
    }
  }
</style>

<script>
  if ("scrollRestoration" in history) {
    history.scrollRestoration = "manual";
  }

  function initScrollReveal() {
    const titles = document.querySelectorAll<HTMLElement>(".cta__title");

    if (!titles.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
          } else {
            entry.target.classList.remove("in-view");
          }
        });
      },
      {
        threshold: 0,
        rootMargin: "0px 0px -5% 0px",
      },
    );

    titles.forEach((title) => observer.observe(title));
  }

  initScrollReveal();

  document.addEventListener("astro:page-load", initScrollReveal);
</script>
