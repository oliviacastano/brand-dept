---
import Button from "./Button.astro";

interface Props {
  title?: string;
  buttonText?: string;
  href?: string;
}

const {
  title = "Bereit für deinen neuen Auftritt?",
  buttonText = "Projekt Anfrage",
  href = "/Kontakt",
} = Astro.props;
---

<section class="cta">
  <div class="container cta__inner">
    <h2 class="cta__title" data-reveal>{title}</h2>
    <Button text={buttonText} href={href} variant="black" />
  </div>
</section>

<style>
  .cta {
    padding-block: var(--space-5xl);
    background: var(--color-background-pink);
    overflow: hidden;
  }

  .cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    text-align: center;
  }

  .cta__title {
    max-width: 40rem;
    font-size: var(--text-h1-size);
    line-height: var(--text-h1-lh);
    color: var(--color-black);
  }

  @media (max-width: 900px) {
    .cta__title {
      font-size: var(--text-h2-size);
      line-height: var(--text-h2-lh);
      max-width: 25rem;
    }
  }
</style>
