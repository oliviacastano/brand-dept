---
interface Props {
  title: string;
  subtitle: string;
  href: string;
  image?: ImageMetadata;
  imageAlt?: string;
  theme?: string;
  reveal?: boolean;
}

const {
  title,
  subtitle,
  href,
  image,
  imageAlt,
  theme = "dark",
  reveal = false,
} = Astro.props;
---

<a
  href={href}
  class={`project-card project-card--${theme}`}
  data-reveal={reveal ? "" : undefined}
>
  <div class="project-card__image">
    {
      image ? (
        <img src={image.src} alt={imageAlt ?? title} />
      ) : (
        <div class="project-card__mockup">
          <span />
          <div />
          <div />
          <div />
          <button />
        </div>
      )
    }
  </div>

  <div class="project-card__content">
    <div>
      <h3>{title}</h3>
      <p>{subtitle}</p>
    </div>

    <span class="project-card__arrow">↗</span>
  </div>
</a>

<style>
  .project-card {
    color: var(--color-black);
    text-decoration: none;
  }

  .project-card__image {
    height: 18rem;
    border: 1px solid rgba(47, 2, 18, 0.08);
    overflow: hidden;
    background: rgba(201, 107, 126, 0.16);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .project-card__image {
    transform: translateY(-0.5rem);
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-card__content {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .project-card h3 {
    font-size: var(--text-h4-size);
    line-height: var(--text-h4-lh);
  }

  .project-card p {
    color: rgba(47, 2, 18, 0.45);
    font-size: var(--text-p-small-size);
    line-height: var(--text-p-small-lh);
  }

  .project-card__arrow {
    color: var(--color-dark-pink);
  }
</style>
