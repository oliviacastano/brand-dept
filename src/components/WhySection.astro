---
interface StatItem {
  value: string;
  label: string;
}

interface Props {
  title?: string;
  text?: string;
  stats?: StatItem[];
}

const {
  title = "Warum Brand Dept?",
  text = `Ich glaube daran, dass jedes Unternehmen einen professionellen Auftritt verdient – auch kleine Betriebe und Selbstständige, für die grosse Agenturpreise oft nicht drin liegen.

Meine Lehre als Mediamatikerin in einer Webagentur hat mir das nötige Handwerk mitgegeben – von Design über Umsetzung bis zu sauberem, wartbarem Code. Dieses Wissen gebe ich bewusst schlank weiter: kein grosses Büro, keine Agenturkosten, dafür faire Preise bei gleichbleibend hoher Qualität.

Brand Dept mache ich nicht des Geldes wegen, sondern weil es mir Spass macht und ich mich stetig weiterentwickeln will. Mein Ziel ist es, mir damit eine eigene Firma aufzubauen – und Unternehmen eine gute Website zu ermöglichen, die sich teure Agenturen sonst nicht leisten könnten.`,
  stats = [
    { value: "100 %", label: "Individuell" },
    { value: "0", label: "Vorlagen" },
    { value: "1", label: "Ansprechpartner" },
    { value: "∞", label: "Liebe zum Detail" },
  ],
} = Astro.props;
---

<section class="why">
  <div class="container why__inner">
    <div class="why__top">
      <h2 class="why__title" data-reveal>
        {title}
      </h2>

      <p class="why__text" data-reveal>
        {text}
      </p>
    </div>

    <div class="why__stats">
      {
        stats.map((stat) => (
          <article class="why-stat" data-reveal>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why {
    padding-block: var(--space-5xl);
    background: var(--color-background-pink);
  }

  .why__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5xl);
  }

  .why__top {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-5xl);
  }

  .why__title {
    max-width: 24rem;
    font-size: var(--text-h2-size);
    line-height: var(--text-h2-lh);
    color: var(--color-black);
  }

  .why__text {
    max-width: 34rem;
    white-space: pre-line;
    font-size: var(--text-p-size);
    line-height: var(--text-p-lh);
    color: var(--color-black);
  }

  .why__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4xl);
    padding-top: var(--space-4xl);
    border-top: 1px solid rgba(201, 107, 126, 0.25);
  }

  .why-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .why-stat strong {
    color: var(--color-dark-pink);
    font-size: var(--text-h2-size);
    line-height: 1;
    font-weight: var(--font-weight-bold);
  }

  .why-stat span {
    font-size: var(--text-p-size);
    line-height: var(--text-p-lh);
    color: var(--color-black);
  }

  @media (max-width: 900px) {
    .why__top {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .why__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl);
    }
  }

  @media (max-width: 600px) {
    .why__stats {
      grid-template-columns: 1fr;
    }
  }
</style>
