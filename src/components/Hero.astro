---
import Button from "./Button.astro";

interface ButtonItem {
  text: string;
  href: string;
  variant?: "pink" | "black" | "link";
}

interface Props {
  label?: string;
  text?: string;
  buttons?: ButtonItem[];
  image?: ImageMetadata;
  imageAlt?: string;
  rightText?: string;
}

const {
  label,
  text,
  buttons = [],
  image,
  imageAlt = "",
  rightText,
} = Astro.props;

const visualClass = image
  ? "hero__visual hero__visual--image"
  : "hero__visual hero__visual--text";
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      {label && <p class="hero__label label">{label}</p>}

      <h1 class="hero__title">
        <slot name="title" />
      </h1>

      {text && <p class="hero__text">{text}</p>}

      {
        buttons.length > 0 && (
          <div class="hero__buttons">
            {buttons.map((button) => (
              <Button
                text={button.text}
                href={button.href}
                variant={button.variant}
              />
            ))}
          </div>
        )
      }
    </div>

    <div class={visualClass}>
      {image && <img src={image.src} alt={imageAlt} />}
      {!image && rightText && <p>{rightText}</p>}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-xl) var(--space-5xl) 0 var(--space-5xl);
    background: var(--color-background);
    margin-top: var(--space-xl);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(22rem, 1fr);
    gap: var(--space-5xl);
    align-items: stretch;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
  }

  .hero__label {
    position: relative;
    margin-bottom: var(--space-md);
    color: var(--color-dark-pink);
  }

  .hero__label::before {
    content: "";
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    margin-right: var(--space-md);
    vertical-align: middle;
    background: var(--color-dark-pink);
  }

  .hero__title {
    max-width: 45rem;
  }

  .hero__title :global(.pink) {
    color: var(--color-dark-pink);
  }

  .hero__text {
    max-width: 38rem;
    margin-top: var(--space-xl);
    font-size: var(--text-p-size);
    line-height: var(--text-p-lh);
  }

  .hero__buttons {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .hero__visual {
    width: 100%;
    min-height: 100%;
    display: flex;
  }

  .hero__visual--image {
    justify-content: center;
    align-items: center;
  }

  .hero__visual--text {
    justify-content: flex-start;
    align-items: flex-end;
  }

  .hero__visual img {
    width: 100%;
    max-width: 34rem;
    height: auto;
    display: block;
  }

  .hero__visual p {
    max-width: 28rem;
    font-size: var(--text-p-size);
    line-height: var(--text-p-lh);
    color: rgba(47, 2, 18, 0.55);
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .hero__visual--text {
      align-items: flex-start;
    }

    .hero__visual--image {
      justify-content: flex-start;
    }
  }
</style>
