---
import ServiceItem from "./ServiceItem.astro";
import SectionHeading from "./SectionHeading.astro";

const services = [
  {
    number: "01",
    title: "Webdesign",
    text: "Maßgeschneiderte Designs, die deine Marke authentisch widerspiegeln.",
    href: "/Leistungen",
  },
  {
    number: "02",
    title: "Entwicklung",
    text: "Schnelle und saubere Umsetzung mit modernen Technologien.",
    href: "/Leistungen",
  },
  {
    number: "03",
    title: "Branding",
    text: "Ein starker Markenauftritt mit klarer visueller Identität.",
    href: "/Leistungen",
  },
  {
    number: "04",
    title: "Redesign",
    text: "Bestehende Websites neu denken und gezielt verbessern.",
    href: "/Leistungen",
  },
  {
    number: "05",
    title: "Pflege & Wartung",
    text: "Laufende Betreuung, Updates und technischer Support.",
    href: "/Leistungen",
  },
];
---

<section class="services">
  <div class="container">
    <SectionHeading label="Leistungen"> Was ich anbiete </SectionHeading>

    <div class="services__list">
      {services.map((service) => <ServiceItem {...service} />)}
    </div>
  </div>
</section>

<style>
  .services {
    padding-block: var(--space-5xl);
  }

  .services__heading {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-4xl);
  }

  .services__heading span {
    width: 1.5rem;
    height: 1px;
    background: var(--color-dark-pink);
  }
</style>
