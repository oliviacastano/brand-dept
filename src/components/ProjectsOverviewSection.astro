---
import { projects } from "../data/projects";
---

<section class="projects-overview">
  <div class="container">
    <div class="projects-overview__list">
      {
        projects.map((project, index) => (
          <a href={`/Projekte/${project.slug}`} class="project-row">
            <div class="project-row__number">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <span>{project.year}</span>
            </div>

            <div
              class={`project-row__image project-row__image--${project.theme}`}
            >
              <img src={project.image.src} alt={project.imageAlt} />
            </div>

            <div class="project-row__title">
              <h2>{project.title}</h2>
              <p>{project.category}</p>
              <span />
            </div>

            <div class="project-row__content">
              <p>{project.description}</p>

              <div class="project-row__tags">
                {project.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-overview {
    padding-block: var(--space-5xl);
    background: var(--color-background);
  }

  .project-row {
    display: grid;
    grid-template-columns: 4rem 18rem 1fr 1.2fr;
    gap: var(--space-2xl);
    padding-block: var(--space-3xl);
    border-bottom: 1px solid rgba(47, 2, 18, 0.1);
    color: var(--color-black);
    text-decoration: none;
  }

  .project-row:first-child {
    border-top: 1px solid rgba(47, 2, 18, 0.1);
  }

  .project-row__number {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    color: rgba(47, 2, 18, 0.45);
    font-size: var(--text-p-small-size);
  }

  .project-row__image {
    height: 14rem;
    border-radius: 0.35rem;
    overflow: hidden;
    background: rgba(47, 2, 18, 0.08);
  }

  .project-row__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-row__title h2 {
    margin-bottom: var(--space-sm);
    font-size: var(--text-h3-size);
    line-height: var(--text-h3-lh);
    font-weight: var(--font-weight-regular);
  }

  .project-row__title p,
  .project-row__content p {
    color: rgba(47, 2, 18, 0.5);
    font-size: var(--text-p-small-size);
    line-height: var(--text-p-small-lh);
  }

  .project-row__title span {
    display: block;
    width: 1.5rem;
    height: 1px;
    margin-top: var(--space-md);
    background: var(--color-dark-pink);
  }

  .project-row__tags {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .project-row__tags span {
    padding: var(--space-xs) var(--space-md);
    border: 1px solid rgba(47, 2, 18, 0.12);
    font-size: var(--text-p-small-size);
  }
</style>
