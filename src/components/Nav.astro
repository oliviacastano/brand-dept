---
import { projects } from "../data/projects";

// Seiten, die es zwar gibt, die aber nicht in der Hauptnavigation
// erscheinen sollen (z. B. weil sie nur im Footer verlinkt sind).
const HIDDEN_FROM_NAV = ["impressum", "datenschutz"];

const pages = import.meta.glob("/src/pages/**/index.astro");

const links = Object.keys(pages)
  .map((path) => {
    const url =
      path.replace("/src/pages", "").replace("/index.astro", "") || "/";

    const segments = url.split("/").filter(Boolean);

    return {
      url,
      name: segments[0],
      depth: segments.length,
    };
  })
  .filter((link) => link.depth === 1)
  .filter((link) => !HIDDEN_FROM_NAV.includes(link.name.toLowerCase()))
  .filter((link) => link.name.toLowerCase() !== "projekte" || projects.length > 0)
  .sort((a, b) => a.url.localeCompare(b.url));
---

<nav class="nav">
  <ul class="nav__list">
    {
      links.map((link) => (
        <li class="nav__item">
          <a class="nav__link" href={link.url}>
            {link.name}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav {
    height: 100%;
  }

  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    list-style: none;
  }

  .nav__item {
    margin: 0;
    padding: 0;
  }

  .nav__link {
    display: block;
    color: var(--color-black);
    text-decoration: none;
    font-size: var(--text-p-small-size);
    line-height: var(--text-p-small-lh);
    font-weight: var(--font-weight-regular);
    transition: color 0.2s ease;
    text-transform: capitalize;
  }

  .nav__link:hover {
    color: var(--color-dark-pink);
  }

  @media (max-width: 860px) {
    .nav {
      width: 100%;
    }

    .nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }

    .nav__link {
      font-size: var(--text-p-size);
    }
  }
</style>
