---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";

const featuredProjects = [...projects].sort(() => Math.random() - 0.5).slice(0, 3);
---

{
  featuredProjects.length > 0 && (
    <section class="projects-section">
      <div class="container">
        <div class="projects-section__heading" data-reveal>
          <span />
          <h2>Projekte</h2>
        </div>

        <div class="projects-section__grid">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.title}
              subtitle={project.subtitle}
              href={`/Projekte/${project.slug}`}
              image={project.image}
              imageAlt={project.imageAlt}
              theme={project.theme}
              reveal
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .projects-section {
    padding-block: var(--space-5xl);
  }

  .projects-section__heading {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-4xl);
  }

  .projects-section__heading span {
    width: 1.5rem;
    height: 1px;
    background: var(--color-dark-pink);
  }

  .projects-section__heading h2 {
    font-size: var(--text-h2-size);
    line-height: var(--text-h2-lh);
  }

  .projects-section__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
  }

  @media (max-width: 900px) {
    .projects-section__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
