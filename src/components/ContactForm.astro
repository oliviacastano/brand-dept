    margin-bottom: var(--space-xs);
    font-size: var(--text-h4-size);
  }

  .contact__info a,
  .contact__info p {
    color: var(--color-black);
    text-decoration: none;
  }

  .contact__form {
    display: grid;
    gap: var(--space-lg);
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  label {
    display: grid;
    gap: var(--space-xs);
    color: rgba(47, 2, 18, 0.65);
    font-size: var(--text-label-size);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgba(47, 2, 18, 0.12);
    background: transparent;
    padding: var(--space-md);
    font: inherit;
    color: var(--color-black);
  }

  textarea {
    min-height: 12rem;
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(47, 2, 18, 0.25);
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
