<section class="contact">
  <div class="container contact__inner">
    <div class="contact__info">
      <p>
        Erzähl mir von deinem Unternehmen und deinen Zielen. Ich melde mich
        innerhalb von 24 Stunden bei dir zurück – persönlich und unkompliziert.
      </p>

      <div>
        <h3>E-Mail</h3>
        <a href="mailto:hello@niora.ch">hello@niora.ch</a>
      </div>

      <div>
        <h3>Antwortzeit</h3>
        <p>Innerhalb von 24 Stunden</p>
      </div>

      <div>
        <h3>Standort</h3>
        <p>Schweiz</p>
      </div>
    </div>

    <form
      class="contact__form"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value="DEIN_ACCESS_KEY_HIER" />
      <input
        type="hidden"
        name="subject"
        value="Neue Projektanfrage über Brand Dept"
      />

      <div class="contact__row">
        <label>
          Name *
          <input type="text" name="name" placeholder="Dein Name" required />
        </label>

        <label>
          E-Mail *
          <input
            type="email"
            name="email"
            placeholder="deine@email.ch"
            required
          />
        </label>
      </div>

      <label>
        Unternehmen
        <input type="text" name="company" placeholder="Dein Unternehmensname" />
      </label>

      <label>
        Ich interessiere mich für
        <select name="interest">
          <option value="">Bitte auswählen</option>
          <option value="Webdesign">Webdesign</option>
          <option value="Branding">Branding</option>
          <option value="Entwicklung">Entwicklung</option>
          <option value="Redesign">Redesign</option>
        </select>
      </label>

      <label>
        Nachricht *
        <textarea
          name="message"
          placeholder="Was planst du? Was brauchst du?"
          required></textarea>
      </label>

      <div class="contact__bottom">
        <p>* Pflichtfelder</p>
        <button type="submit">Absenden</button>
      </div>
    </form>
  </div>
</section>

<style>
